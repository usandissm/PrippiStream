<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.prippistream" name="PrippiStream" version="1.1.0" provider-name="usandissm">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <!-- <import addon="script.module.libtorrent" optional="true"/> -->
    <!-- inputstream stack declared explicitly so Kodi installs+enables it WITH
         the addon, instead of relying on it being pulled transitively through the
         (optional) youtube import. Without this, a fresh install that skips the
         optional youtube branch ends up without ISA/helper and re-prompts to
         download them on first playback. -->
    <import addon="inputstream.adaptive"/>
    <import addon="inputstream.ffmpegdirect"/>
    <import addon="script.module.inputstreamhelper"/>
    <!-- Optional fast AES. NOTE: script.module.pycryptodome is NOT in the
         official Kodi repo, so it must stay optional (a hard require would make
         the addon unresolvable). Offline-download AES uses Kodi's bundled
         OpenSSL via ctypes (core/native_aes.py); pyaes is the final fallback. -->
    <import addon="script.module.pycryptodome" optional="true"/>
    <import addon="plugin.video.youtube"/>
    <import addon="metadata.themoviedb.org" optional="true"/>
    <import addon="metadata.tvshows.themoviedb.org" optional="true"/>
    <!-- <import addon="metadata.tvdb.com"/> -->
    <!-- <import addon="script.module.web-pdb" /> -->
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">PrippiStream is a Kodi add-on to search and watch contents on the web.</summary>
    <summary lang="it">PrippiStream ├¿ un addon per Kodi per cercare e guardare contenuti sul web.</summary>
    <assets>
      <icon>resources/media/logo.png</icon>
      <fanart>resources/media/fanart.jpg</fanart>
      <screenshot>resources/media/screenshot-1.png</screenshot>
      <screenshot>resources/media/screenshot-2.png</screenshot>
      <screenshot>resources/media/screenshot-3.png</screenshot>
    </assets>
      <news>- Bug fix.
- Upgrade vari.
- Aggiunta della funzione Download offline: scarica film ed episodi e guardali senza connessione dalla sezione "I miei download", con scelta della qualità, selezione multipla degli episodi e avanzamento rapido durante la riproduzione.
</news>
    <description lang="it">Naviga velocemente sul web e guarda i contenuti presenti</description>
    <disclaimer>[COLOR red]The owners and submitters to this addon do not host or distribute any of the content displayed by these addons nor do they have any affiliation with the content providers.[/COLOR]
    [COLOR yellow]Kodi ┬® is a registered trademark of the XBMC Foundation. We are not connected to or in any other way affiliated with Kodi, Team Kodi, or the XBMC Foundation. Furthermore, any software, addons, or products offered by us will receive no support in official Kodi channels, including the Kodi forums and various social networks.[/COLOR]</disclaimer>
    <platform>all</platform>
    <license>GNU GPL v3</license>
    <website>https://github.com/usandissm/PrippiStream</website>
    <source>https://github.com/usandissm/PrippiStream</source>
  </extension>
  <extension point="xbmc.service" library="service.py" start="login|startup">
  </extension>
</addon>
<addon id="repository.prippistream" name="PrippiStream Repository" version="1.0.0" provider-name="usandissm">
  <extension point="xbmc.addon.repository" name="PrippiStream Repository">
    <dir>
      <info compressed="false">https://usandissm.github.io/PrippiStream/addons.xml</info>
      <checksum>https://usandissm.github.io/PrippiStream/addons.xml.md5</checksum>
      <datadir zip="true">https://usandissm.github.io/PrippiStream/</datadir>
      <minversion>0.0.0</minversion>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">PrippiStream Repository</summary>
    <summary lang="it">Repository di PrippiStream</summary>
    <description lang="it">Repository ufficiale di PrippiStream</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
</addons>
