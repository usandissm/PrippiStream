<?xml version="1.0" encoding="utf-8"?>
<!--
  DetailWindow.xml — 1280x720  Cinema Mode  PrippiStream
  Coords = 1080i x 2/3  |  bg rect: top=280, h=440 (fills to y=720, no gap)
  id=223 EpInfo + id=215 EpSel: visible=false, shown by Python for tvshow items
-->
<window type="dialog">
    <allowmouse>true</allowmouse>
    <defaultcontrol>210</defaultcontrol>
    <animation type="WindowOpen" reversible="false">
        <effect type="fade" start="0" end="100" time="200" tween="sine"/>
    </animation>
    <animation type="WindowClose" reversible="false">
        <effect type="fade" start="100" end="0" time="140" tween="sine"/>
    </animation>

    <controls>

        <control type="image">
            <left>0</left><top>0</top><width>1280</width><height>720</height>
            <texture colordiffuse="FF0D0D0D">white.png</texture>
        </control>

        <control type="videowindow" id="202">
            <left>0</left><top>0</top><width>1280</width><height>720</height>
        </control>

        <control type="image" id="201">
            <left>0</left><top>0</top><width>1280</width><height>720</height>
            <texture>-</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <control type="group" id="230">
            <animation type="Hidden">
                <effect type="fade" start="100" end="0" time="800" tween="sine"/>
            </animation>
            <animation type="Visible">
                <effect type="fade" start="0" end="100" time="300" tween="sine"/>
            </animation>

            <!-- Top bar tint -->
            <control type="image">
                <left>0</left><top>0</top><width>1280</width><height>52</height>
                <texture colordiffuse="A0000000">white.png</texture>
            </control>

            <!-- Brand -->
            <control type="label">
                <left>28</left><top>12</top><width>300</width><height>24</height>
                <font>font14</font><textcolor>FFFFFFFF</textcolor>
                <shadowcolor>CC000000</shadowcolor>
                <label>[B]PRIPPI[COLOR FFE50914]STREAM[/COLOR][/B]</label>
            </control>

            <!-- Red accent line -->
            <control type="image">
                <left>0</left><top>48</top><width>1280</width><height>2</height>
                <texture colordiffuse="FFE50914">white.png</texture>
            </control>

            <!-- CHIUDI id=212 -->
            <control type="button" id="212">
                <left>1160</left><top>10</top><width>100</width><height>28</height>
                <texturefocus colordiffuse="FFE50914">white.png</texturefocus>
                <texturenofocus colordiffuse="28FFFFFF">white.png</texturenofocus>
                <label>[B]&#10005;  CHIUDI[/B]</label>
                <font>font10</font><textcolor>FF999999</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
                <align>center</align>
                <ondown>210</ondown><onleft>213</onleft>
                <animation effect="zoom" start="100" end="108" center="auto" time="120" tween="sine" easing="out">Focus</animation>
                <animation effect="zoom" start="108" end="100" center="auto" time="90" tween="sine" easing="in">Unfocus</animation>
            </control>

            <!-- ONE background rect fills y=280..720 — no bottom gap -->
            <control type="image">
                <left>0</left><top>280</top><width>1280</width><height>440</height>
                <texture colordiffuse="E80D0D0D">white.png</texture>
            </control>

            <!-- Title id=204 — narrowed to leave room for EP selector on right -->
            <control type="label" id="204">
                <left>48</left><top>287</top><width>413</width><height>36</height>
                <font>font14</font><textcolor>FFFFFFFF</textcolor>
                <shadowcolor>D0000000</shadowcolor>
                <label></label><align>left</align><aligny>center</aligny>
            </control>

            <!-- STAGIONI & EPISODI button id=215 — right of title, tvshow only -->
            <control type="button" id="215">
                <left>487</left><top>285</top><width>387</width><height>38</height>
                <texturefocus colordiffuse="C8E50914">white.png</texturefocus>
                <texturenofocus colordiffuse="30FFFFFF">white.png</texturenofocus>
                <label>[B]&#9776;  STAGIONI &amp; EPISODI[/B]</label>
                <font>font12</font><textcolor>FFCCCCCC</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
                <align>center</align>
                <onup>209</onup><ondown>210</ondown><onleft>212</onleft><onright>211</onright>
                <visible>!String.IsEmpty(Window.Property(is_tvshow))</visible>
                <animation effect="zoom" start="100" end="106" center="auto" time="130" tween="sine" easing="out">Focus</animation>
                <animation effect="zoom" start="106" end="100" center="auto" time="100" tween="sine" easing="in">Unfocus</animation>
            </control>

            <!-- Ep info label id=223 — below EP button, tvshow only -->
            <control type="label" id="223">
                <left>487</left><top>326</top><width>746</width><height>16</height>
                <font>font12</font><textcolor>FF888888</textcolor>
                <shadowcolor>CC000000</shadowcolor>
                <label></label>
                <visible>!String.IsEmpty(Window.Property(is_tvshow))</visible>
            </control>

            <!-- Meta1 id=205 -->
            <control type="label" id="205">
                <left>48</left><top>325</top><width>1184</width><height>16</height>
                <font>font12</font><textcolor>FFFFFFFF</textcolor>
                <shadowcolor>CC000000</shadowcolor><label></label>
            </control>

            <!-- Meta2 id=206 -->
            <control type="label" id="206">
                <left>48</left><top>343</top><width>1184</width><height>13</height>
                <font>font12</font><textcolor>FF888888</textcolor>
                <shadowcolor>CC000000</shadowcolor><label></label>
            </control>

            <!-- Meta3 id=207 -->
            <control type="label" id="207">
                <left>48</left><top>358</top><width>1184</width><height>13</height>
                <font>font12</font><textcolor>FF666666</textcolor>
                <shadowcolor>CC000000</shadowcolor><label></label>
            </control>

            <!-- Tagline id=208 -->
            <control type="label" id="208">
                <left>48</left><top>373</top><width>960</width><height>12</height>
                <font>font12</font><textcolor>FF4A4A4A</textcolor>
                <shadowcolor>CC000000</shadowcolor><label></label>
            </control>

            <!-- Divider above plot -->
            <control type="image">
                <left>48</left><top>387</top><width>1184</width><height>2</height>
                <texture colordiffuse="20FFFFFF">white.png</texture>
            </control>

            <!-- Plot id=209 (scrollable, h=87 — taller than before) -->
            <control type="textbox" id="209">
                <left>48</left><top>390</top><width>1184</width><height>87</height>
                <font>font12</font><textcolor>FFBBBBBB</textcolor>
                <shadowcolor>CC000000</shadowcolor>
                <scroll>true</scroll><autoscroll>false</autoscroll>
                <ondown>215</ondown><onleft>210</onleft><onright>211</onright>
            </control>

            <!-- Divider above cast/ep section -->
            <control type="image">
                <left>48</left><top>479</top><width>1184</width><height>2</height>
                <texture colordiffuse="14FFFFFF">white.png</texture>
            </control>

            <!-- Cast header id=221 (visible=false) -->
            <control type="label" id="221">
                <left>48</left><top>483</top><width>200</width><height>14</height>
                <font>font10</font><textcolor>FF444444</textcolor>
                <shadowcolor>CC000000</shadowcolor>
                <label>[B]CAST[/B]</label><visible>false</visible>
            </control>

            <!-- Cast panel id=220 (visible=false) -->
            <control type="panel" id="220">
                <left>0</left><top>499</top><width>1280</width><height>54</height>
                <scrolltime tween="cubic" easing="out">200</scrolltime>
                <scrollwrap>false</scrollwrap>
                <onup>209</onup><ondown>215</ondown><visible>false</visible>
                <itemlayout height="54" width="80">
                    <control type="image">
                        <left>10</left><top>3</top><width>60</width><height>42</height>
                        <texture colordiffuse="18FFFFFF">white.png</texture>
                    </control>
                    <control type="image">
                        <left>10</left><top>3</top><width>60</width><height>42</height>
                        <texture>$INFO[ListItem.Property(actor_thumb)]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>
                    <control type="label">
                        <left>0</left><top>46</top><width>80</width><height>11</height>
                        <font>font10</font><textcolor>FF555555</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <align>center</align><truncated>true</truncated>
                    </control>
                </itemlayout>
                <focusedlayout height="54" width="80">
                    <control type="image">
                        <left>6</left><top>1</top><width>68</width><height>44</height>
                        <texture colordiffuse="CCE50914">white.png</texture>
                        <animation effect="fade" start="0" end="100" time="150" tween="sine">Focus</animation>
                        <animation effect="fade" start="100" end="0" time="110" tween="sine">Unfocus</animation>
                    </control>
                    <control type="image">
                        <left>10</left><top>3</top><width>60</width><height>40</height>
                        <texture>$INFO[ListItem.Property(actor_thumb)]</texture>
                        <aspectratio>scale</aspectratio>
                        <animation effect="zoom" start="100" end="105" center="auto" time="150" tween="sine" easing="out">Focus</animation>
                        <animation effect="zoom" start="105" end="100" center="auto" time="110" tween="sine" easing="in">Unfocus</animation>
                    </control>
                    <control type="label">
                        <left>0</left><top>46</top><width>80</width><height>11</height>
                        <font>font10</font><textcolor>FFFFFFFF</textcolor>
                        <shadowcolor>FF000000</shadowcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <align>center</align><truncated>true</truncated>
                    </control>
                </focusedlayout>
            </control>

            <!-- Divider above buttons -->
            <control type="image">
                <left>0</left><top>584</top><width>1280</width><height>2</height>
                <texture colordiffuse="20FFFFFF">white.png</texture>
            </control>

            <!-- GUARDA id=210 -->
            <control type="button" id="210">
                <left>48</left><top>588</top><width>176</width><height>34</height>
                <texturefocus colordiffuse="FFE50914">white.png</texturefocus>
                <texturenofocus colordiffuse="50E50914">white.png</texturenofocus>
                <label>[B]&#9654;  GUARDA[/B]</label>
                <font>font12</font><textcolor>FFD8D8D8</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
                <align>center</align>
                <onup>215</onup><onleft>212</onleft><onright>211</onright>
                <animation effect="zoom" start="100" end="106" center="auto" time="130" tween="sine" easing="out">Focus</animation>
                <animation effect="zoom" start="106" end="100" center="auto" time="100" tween="sine" easing="in">Unfocus</animation>
            </control>

            <!-- AUDIO / SUB id=211 -->
            <control type="button" id="211">
                <left>236</left><top>588</top><width>176</width><height>34</height>
                <texturefocus colordiffuse="C0FFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="24FFFFFF">white.png</texturenofocus>
                <label>[B]AUDIO / SUB[/B]</label>
                <font>font12</font><textcolor>FFAAAAAA</textcolor><focusedcolor>FF0D0D0D</focusedcolor>
                <align>center</align>
                <onup>215</onup><onleft>210</onleft><onright>213</onright>
                <animation effect="zoom" start="100" end="106" center="auto" time="130" tween="sine" easing="out">Focus</animation>
                <animation effect="zoom" start="106" end="100" center="auto" time="100" tween="sine" easing="in">Unfocus</animation>
            </control>

            <!-- TOGLI DAI RECENTI id=213 -->
            <control type="button" id="213">
                <left>424</left><top>588</top><width>196</width><height>34</height>
                <texturefocus colordiffuse="AAFF3333">white.png</texturefocus>
                <texturenofocus colordiffuse="22FF3333">white.png</texturenofocus>
                <label>[B]&#10005;  TOGLI DAI RECENTI[/B]</label>
                <font>font12</font><textcolor>FFAAAAAA</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
                <align>center</align>
                <onup>215</onup><onleft>211</onleft><onright>212</onright>
                <visible>!String.IsEmpty(Window.Property(show_remove_cw))</visible>
                <animation effect="zoom" start="100" end="106" center="auto" time="130" tween="sine" easing="out">Focus</animation>
                <animation effect="zoom" start="106" end="100" center="auto" time="100" tween="sine" easing="in">Unfocus</animation>
            </control>

        </control>
        <!-- end cinema group id=230 -->

    </controls>
</window>
