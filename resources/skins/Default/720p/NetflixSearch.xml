            <texturenofocus colordiffuse="18FFFFFF">white.png</texturenofocus>
            <label>TUTTI</label>
            <font>font12</font>
            <textcolor>FFCCCCCC</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onright>141</onright>
            <onup>120</onup>
            <ondown>160</ondown>
