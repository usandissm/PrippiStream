                <control type="label">
                    <left>14</left><top>12</top>
                    <width>86</width><height>26</height>
                    <font>font10</font><align>center</align><aligny>center</aligny>
                    <textcolor>FFA78BFA</textcolor>
                    <label>[B]ANIME[/B]</label>
                    <visible>String.IsEqual(ListItem.Property(stype),ANIME)</visible>
                </control>
                <control type="label">
                    <left>14</left><top>12</top>
                    <width>86</width><height>26</height>
                    <font>font10</font><align>center</align><aligny>center</aligny>
                    <textcolor>FF38BDF8</textcolor>
                    <label>[B]FILM[/B]</label>
                    <visible>String.IsEqual(ListItem.Property(stype),FILM)</visible>
                </control>
                <control type="label">
                    <left>14</left><top>12</top>
                    <width>86</width><height>26</height>
                    <font>font10</font><align>center</align><aligny>center</aligny>
                    <textcolor>FF4ADE80</textcolor>
                    <label>[B]SERIE[/B]</label>
                    <visible>String.IsEqual(ListItem.Property(stype),SERIE)</visible>
