<?xml version="1.0" encoding="utf-8"?>
<!--
  NetflixSearch.xml — 1920×1080  (redesign 2026-06)
  Grid-first unified search overlay for PrippiStream.

  Layout (no overlapping hero/buttons):
    Top bar    (0–88)    : logo image | query/re-search | EXIT
    Filter bar (88–160)  : chips Tutti/Film/Serie/Anime + result-count label
    Divider    (160–163) :
    Grid       (168–928) : centered poster grid (7 cols × 2 full rows) with type badge
    Context    (936–970) : focused item — title (left) + meta type·year·rating (right)
    Status     (996–1080): loading bar + "Ricerca in corso..." (BELOW the grid)

  Control IDs:
    109  (legacy) back — ESC/Back key handled in onAction (no button here)
    120  query / re-search button
    121  result-count / progress label
    122  EXIT button
    140  filter chip: Tutti      141  filter chip: Film
    142  filter chip: Serie      143  filter chip: Anime
    132  context title           133  context meta (type · year · rating)
    160  poster grid panel
    170  loading group           171  no-results label          172  status text

  Per-card ListItem properties (set in netflixhome.py _populate_grid):
    thumbnail  → poster URL
    stype      → ANIME | FILM | SERIE  (drives the badge colour/visibility)
-->
<window>
    <allowmouse>true</allowmouse>
    <defaultcontrol>160</defaultcontrol>

    <animation type="WindowOpen" reversible="false">
        <effect type="fade" start="0" end="100" time="230" tween="sine"/>
    </animation>
    <animation type="WindowClose" reversible="false">
        <effect type="fade" start="100" end="0" time="150" tween="sine"/>
    </animation>

    <controls>

        <!-- ═══════════════════════════════════════════════════════════
             BASE: full-screen opaque dark background
        ═══════════════════════════════════════════════════════════ -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>1080</height>
            <texture colordiffuse="FA0D0D0D">white.png</texture>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             TOP BAR (height=88)
        ═══════════════════════════════════════════════════════════ -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>88</height>
            <texture colordiffuse="E8000000">white.png</texture>
        </control>

        <!-- Brand logo (same image as the home) -->
        <control type="image">
            <left>28</left><top>-4</top>
            <width>360</width><height>96</height>
            <texture>special://home/addons/plugin.video.prippistream/resources/media/logo_banner.png</texture>
            <aspectratio>keep</aspectratio>
        </control>

        <!-- Query / re-search button (id=120) -->
        <control type="button" id="120">
            <left>470</left><top>23</top>
            <width>1000</width><height>44</height>
            <texturefocus colordiffuse="38FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="1CFFFFFF">white.png</texturenofocus>
            <label></label>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>left</align>
            <aligny>center</aligny>
            <textoffsetx>18</textoffsetx>
            <onright>122</onright>
            <ondown>140</ondown>
        </control>

        <!-- EXIT button (id=122) -->
        <control type="button" id="122">
            <left>1788</left><top>23</top>
            <width>104</width><height>44</height>
            <texturefocus colordiffuse="FFE50914">white.png</texturefocus>
            <texturenofocus colordiffuse="24FFFFFF">white.png</texturenofocus>
            <label>[B]EXIT[/B]</label>
            <font>font10</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onleft>120</onleft>
            <ondown>143</ondown>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             FILTER BAR (top=88, height=72)
        ═══════════════════════════════════════════════════════════ -->

        <!-- Chip: Tutti (id=140) -->
