                <!-- title -->
                <control type="label">
                    <left>6</left><top>346</top>
                    <width>228</width><height>24</height>
                    <font>font10</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <shadowcolor>FF000000</shadowcolor>
