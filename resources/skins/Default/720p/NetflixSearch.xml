<?xml version="1.0" encoding="utf-8"?>
<!--
  NetflixSearch.xml — 1920×1080
  Unified search overlay for PrippiStream.
  Layout:
    Top bar   (78px):  back ← | query label | progress | close ✕
    Hero area (210px): left=poster (180×270), right=title/meta/plot/CTA
    Divider   (3px  ):
    Rows area (789px):  3 wraplist rows (SC / Film / Serie TV) each 261px + 3px divider
    Status bar(30px ):  "Ricerca in corso..." or hidden

  Control IDs:
    Top bar:
      109 ← BACK button
      120  query/title label
      121  progress label  (e.g. "SC · 6/12 canali...")
      122  CLOSE button
    Hero:
      130  hero fanart (background)
      131  hero poster
      132  hero title label
      133  hero meta  label  (year · rating · type)
      134  hero plot  label
      135  PLAY/GUARDA button
      136  INFO/DETAIL button
    Rows:
      150  row-label SC        (label above row 0)
      160  wraplist SC         (id=160)
      151  row-label Film      (label above row 1)
      161  wraplist Film altri (id=161)
      152  row-label Serie TV  (label above row 2)
      162  wraplist Serie TV   (id=162)
    State:
      170  loading overlay group
      171  no-results label
      172  searching-SC label
-->
<window>
    <defaultcontrol>160</defaultcontrol>

    <animation type="WindowOpen" reversible="false">
        <effect type="fade" start="0" end="100" time="230" tween="sine"/>
    </animation>
    <animation type="WindowClose" reversible="false">
        <effect type="fade" start="100" end="0" time="150" tween="sine"/>
    </animation>

    <controls>

        <!-- ═══════════════════════════════════════════════════════════
             BASE: full-screen semi-transparent dark overlay
        ═══════════════════════════════════════════════════════════ -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>1080</height>
            <texture colordiffuse="F00D0D0D">white.png</texture>
        </control>

        <!-- Hero fanart — blurred background, constrained to hero height -->
        <control type="image" id="130">
            <left>0</left><top>78</top>
            <width>1920</width><height>210</height>
            <texture colordiffuse="00FFFFFF">white.png</texture>
            <aspectratio>scale</aspectratio>
        </control>
        <!-- Gradient overlay to keep fanart readable -->
        <control type="image">
            <left>0</left><top>78</top>
            <width>1920</width><height>210</height>
            <texture colordiffuse="CC0D0D0D">white.png</texture>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             TOP BAR (height=78)
        ═══════════════════════════════════════════════════════════ -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>78</height>
            <texture colordiffuse="E8000000">white.png</texture>
        </control>

        <!-- Brand (same as home) -->
        <control type="label">
            <left>42</left><top>21</top>
            <width>285</width><height>36</height>
            <font>font14</font>
            <textcolor>FFFFFFFF</textcolor>
            <shadowcolor>FF000000</shadowcolor>
            <label>[B]PRIPPI[COLOR FFE50914]STREAM[/COLOR][/B]</label>
        </control>

        <!-- Back button (id=109) -->
        <control type="button" id="109">
            <left>330</left><top>18</top>
            <width>120</width><height>42</height>
            <texturefocus colordiffuse="B0E50914">white.png</texturefocus>
            <texturenofocus colordiffuse="24FFFFFF">white.png</texturenofocus>
            <label>[B]BACK[/B]</label>
            <font>font10</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onright>120</onright>
            <ondown>160</ondown>
        </control>

        <!-- Query label — shows the current search text (id=120) -->
        <control type="button" id="120">
            <left>468</left><top>15</top>
            <width>840</width><height>48</height>
            <texturefocus colordiffuse="38FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="20FFFFFF">white.png</texturenofocus>
            <label></label>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>left</align>
            <aligny>center</aligny>
            <textoffsetx>15</textoffsetx>
            <onleft>109</onleft>
            <onright>122</onright>
            <ondown>160</ondown>
        </control>

        <!-- Progress info label (id=121) — e.g. "Ricerca in corso..." / "21 risultati" -->
        <control type="label" id="121">
            <left>470</left><top>24</top>
            <width>1290</width><height>30</height>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <shadowcolor>CC000000</shadowcolor>
            <label></label>
            <align>center</align>
        </control>

        <!-- Close button (id=122) -->
        <control type="button" id="122">
            <left>1785</left><top>18</top>
            <width>93</width><height>42</height>
            <texturefocus colordiffuse="B0E50914">white.png</texturefocus>
            <texturenofocus colordiffuse="24FFFFFF">white.png</texturenofocus>
            <label>[B]EXIT[/B]</label>
            <font>font10</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onleft>120</onleft>
            <ondown>160</ondown>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             HERO AREA (top=78, height=210)
        ═══════════════════════════════════════════════════════════ -->

        <!-- Poster (id=131) — 180×270 centered in 210px row (trimmed bottom) -->
        <control type="image" id="131">
            <left>48</left><top>84</top>
            <width>132</width><height>198</height>
            <texture colordiffuse="00FFFFFF">white.png</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <!-- Hero title (id=132) -->
        <control type="label" id="132">
            <left>204</left><top>87</top>
            <width>1470</width><height>54</height>
            <font>font16</font>
            <textcolor>FFFFFFFF</textcolor>
            <shadowcolor>CC000000</shadowcolor>
            <label></label>
        </control>

        <!-- Hero meta: year · rating · type (id=133) -->
        <control type="label" id="133">
            <left>204</left><top>147</top>
            <width>1200</width><height>27</height>
            <font>font10</font>
            <textcolor>FF22C55E</textcolor>
            <shadowcolor>FF000000</shadowcolor>
            <label></label>
        </control>

        <!-- Hero plot (id=134) -->
        <control type="label" id="134">
            <left>204</left><top>177</top>
            <width>1140</width><height>42</height>
            <font>font10</font>
            <textcolor>FFB8B8B8</textcolor>
            <shadowcolor>FF000000</shadowcolor>
            <label></label>
            <wrapwidth>1140</wrapwidth>
        </control>

        <!-- PLAY button (id=135) -->
        <control type="button" id="135">
            <left>1362</left><top>135</top>
            <width>204</width><height>42</height>
            <texturefocus colordiffuse="FFE50914">white.png</texturefocus>
            <texturenofocus colordiffuse="CC1A1A1A">white.png</texturenofocus>
            <label>[B]GUARDA[/B]</label>
            <font>font10</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onright>136</onright>
            <onup>120</onup>
            <ondown>160</ondown>
        </control>

        <!-- INFO button (id=136) -->
        <control type="button" id="136">
            <left>1578</left><top>135</top>
            <width>192</width><height>42</height>
            <texturefocus colordiffuse="36FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="18FFFFFF">white.png</texturenofocus>
            <label>[B]INFO[/B]</label>
            <font>font10</font>
            <textcolor>FFEBEBEB</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onleft>135</onleft>
            <onup>122</onup>
            <ondown>160</ondown>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             HERO / ROWS DIVIDER
        ═══════════════════════════════════════════════════════════ -->
        <control type="image">
            <left>0</left><top>288</top>
            <width>1920</width><height>2</height>
            <texture colordiffuse="FF1F1F1F">white.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>290</top>
            <width>1920</width><height>3</height>
            <texture colordiffuse="FFE50914">white.png</texture>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             GRID AREA (top=293, height=787) — Netflix-style poster grid
             192px wide items → 10 per row, 265px tall → ~3 rows visible
        ═══════════════════════════════════════════════════════════ -->
        <control type="panel" id="160">
            <left>0</left><top>293</top>
            <width>1920</width><height>787</height>
            <scrolltime tween="cubic" easing="out">220</scrolltime>
            <scrollwrap>false</scrollwrap>
            <onup>120</onup>
            <itemlayout height="380" width="270">
                <control type="image">
                    <left>6</left><top>4</top>
                    <width>258</width><height>340</height>
                    <texture colordiffuse="18000000">white.png</texture>
                </control>
                <control type="image">
                    <left>8</left><top>5</top>
                    <width>254</width><height>340</height>
                    <texture>$INFO[ListItem.Property(thumbnail)]</texture>
                    <aspectratio>scale</aspectratio>
                </control>
                <control type="label">
                    <left>8</left><top>350</top>
                    <width>254</width><height>22</height>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>center</align>
                    <truncated>true</truncated>
                </control>
            </itemlayout>
            <focusedlayout height="380" width="270">
                <control type="image">
                    <left>1</left><top>1</top>
                    <width>268</width><height>372</height>
                    <texture colordiffuse="66000000">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="140" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="100" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>2</left><top>0</top>
                    <width>266</width><height>350</height>
                    <texture colordiffuse="F2FFFFFF">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="160" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="110" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>2</left><top>0</top>
                    <width>266</width><height>4</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="160" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="110" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>4</left><top>2</top>
                    <width>262</width><height>340</height>
                    <texture>$INFO[ListItem.Property(thumbnail)]</texture>
                    <aspectratio>scale</aspectratio>
                    <animation effect="zoom" start="100" end="106" center="auto" time="180" tween="sine" easing="out">Focus</animation>
                    <animation effect="zoom" start="106" end="100" center="auto" time="130" tween="sine" easing="in">Unfocus</animation>
                </control>
                <control type="label">
                    <left>4</left><top>350</top>
                    <width>262</width><height>22</height>
                    <font>font10</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <shadowcolor>FF000000</shadowcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>center</align>
                    <truncated>true</truncated>
                </control>
            </focusedlayout>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             NO RESULTS overlay (id=171)
        ═══════════════════════════════════════════════════════════ -->
        <control type="label" id="171">
            <left>0</left><top>600</top>
            <width>1920</width><height>60</height>
            <font>font14</font>
            <textcolor>FF555555</textcolor>
            <label>Nessun risultato trovato.</label>
            <align>center</align>
            <aligny>center</aligny>
            <visible>false</visible>
        </control>

        <!-- ═══════════════════════════════════════════════════════════
             LOADING INDICATOR (id=170) — animated pulsing bar
        ═══════════════════════════════════════════════════════════ -->
        <control type="group" id="170">
            <!-- Background track -->
            <control type="image">
                <left>48</left><top>1056</top>
                <width>1824</width><height>3</height>
                <texture colordiffuse="FF252525">white.png</texture>
            </control>
            <!-- Animated fill bar -->
            <control type="image">
                <left>48</left><top>1056</top>
                <width>600</width><height>3</height>
                <texture colordiffuse="FFE50914">white.png</texture>
                <animation effect="fade" start="20" end="90" time="700" tween="cubic" loop="true" reversible="true">Visible</animation>
            </control>
            <!-- Status text -->
            <control type="label" id="172">
                <left>48</left><top>1032</top>
                <width>1824</width><height>24</height>
                <font>font10</font>
                <textcolor>FF555555</textcolor>
                <label>Ricerca in corso...</label>
                <align>left</align>
            </control>
        </control>

    </controls>
</window>
