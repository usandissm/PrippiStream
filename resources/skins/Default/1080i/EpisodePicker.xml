<?xml version="1.0" encoding="utf-8"?>
<window type="dialog">
    <allowmouse>true</allowmouse>
    <defaultcontrol>311</defaultcontrol>
    <animation type="WindowOpen" reversible="false">
        <effect type="fade" start="0" end="100" time="160" tween="sine"/>
    </animation>
    <animation type="WindowClose" reversible="false">
        <effect type="fade" start="100" end="0" time="120" tween="sine"/>
    </animation>
    <controls>
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="CC000000">white.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="F01A1A1A">white.png</texture>
        </control>
        <control type="image">
            <left>30</left><top>6</top><width>320</width><height>52</height>
            <aspectratio align="left">keep</aspectratio>
            <texture>special://home/addons/plugin.video.prippistream/resources/media/logo_banner.png</texture>
        </control>
        <control type="label">
            <left>0</left><top>22</top><width>1920</width><height>28</height>
            <font>font12</font><textcolor>FF555555</textcolor>
            <align>center</align>
            <label>SELEZIONA EPISODIO</label>
        </control>
        <control type="button" id="321">
            <left>1740</left><top>15</top><width>150</width><height>42</height>
            <texturefocus colordiffuse="FFE50914">white.png</texturefocus>
            <texturenofocus colordiffuse="28FFFFFF">white.png</texturenofocus>
            <label>[B]CHIUDI[/B]</label>
            <font>font10</font><textcolor>FF999999</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align><ondown>312</ondown>
            <animation effect="zoom" start="100" end="108" center="auto" time="120" tween="sine" easing="out">Focus</animation>
            <animation effect="zoom" start="108" end="100" center="auto" time="90" tween="sine" easing="in">Unfocus</animation>
        </control>
        <control type="image">
            <left>0</left><top>64</top><width>1920</width><height>3</height>
            <texture colordiffuse="FFE50914">white.png</texture>
        </control>
        <!-- Season dropdown trigger button (id=312) -->
        <control type="button" id="312">
            <left>40</left><top>76</top><width>360</width><height>46</height>
            <texturefocus colordiffuse="FFE50914">white.png</texturefocus>
            <texturenofocus colordiffuse="22FFFFFF">white.png</texturenofocus>
            <label>Stagione 1</label>
            <font>font12</font><textcolor>FFEEEEEE</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
            <align>left</align><aligny>center</aligny><textoffsetx>18</textoffsetx>
            <onup>321</onup><ondown>311</ondown>
        </control>
        <!-- down-arrow icon on the right edge of the button -->
        <control type="image">
            <left>366</left><top>88</top><width>22</width><height>22</height>
            <aspectratio>keep</aspectratio>
            <texture colordiffuse="FFBBBBBB">down.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>126</top><width>1920</width><height>2</height>
            <texture colordiffuse="20FFFFFF">white.png</texture>
        </control>
        <control type="list" id="311">
            <left>40</left><top>130</top><width>1840</width><height>910</height>
            <scrolltime tween="cubic" easing="out">200</scrolltime>
            <onup>312</onup>
            <itemlayout height="110" width="1840">
                <control type="image">
                    <left>0</left><top>4</top><width>186</width><height>102</height>
                    <texture colordiffuse="22FFFFFF">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>4</top><width>186</width><height>102</height>
                    <texture>$INFO[ListItem.Art(thumb)]</texture>
                    <aspectratio>scale</aspectratio>
                </control>
                <control type="label">
                    <left>200</left><top>14</top><width>1610</width><height>26</height>
                    <font>font12</font><textcolor>FFBBBBBB</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <truncated>true</truncated>
                </control>
                <control type="label">
                    <left>200</left><top>44</top><width>1420</width><height>20</height>
                    <font>font10</font><textcolor>FF666666</textcolor>
                    <label>$INFO[ListItem.Property(overview)]</label>
                    <truncated>true</truncated>
                </control>
                <control type="label">
                    <left>1640</left><top>46</top><width>196</width><height>18</height>
                    <font>font10</font><textcolor>FF555555</textcolor>
                    <label>$INFO[ListItem.Property(runtime)]</label>
                    <align>right</align>
                </control>
                <control type="image">
                    <left>0</left><top>108</top><width>1840</width><height>2</height>
                    <texture colordiffuse="10FFFFFF">white.png</texture>
                </control>
            </itemlayout>
            <focusedlayout height="110" width="1840">
                <control type="image">
                    <left>0</left><top>0</top><width>1840</width><height>110</height>
                    <texture colordiffuse="14E50914">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="150" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="110" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>0</left><top>0</top><width>6</width><height>110</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="150" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="110" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>0</left><top>4</top><width>186</width><height>102</height>
                    <texture colordiffuse="22FFFFFF">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>4</top><width>186</width><height>102</height>
                    <texture>$INFO[ListItem.Art(thumb)]</texture>
                    <aspectratio>scale</aspectratio>
                </control>
                <control type="label">
                    <left>200</left><top>14</top><width>1610</width><height>26</height>
                    <font>font12</font><textcolor>FFFFFFFF</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <truncated>true</truncated>
                </control>
                <control type="label">
                    <left>200</left><top>44</top><width>1420</width><height>20</height>
                    <font>font10</font><textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[ListItem.Property(overview)]</label>
                    <truncated>true</truncated>
                </control>
                <control type="label">
                    <left>1640</left><top>46</top><width>196</width><height>18</height>
                    <font>font10</font><textcolor>FF777777</textcolor>
                    <label>$INFO[ListItem.Property(runtime)]</label>
                    <align>right</align>
                </control>
                <control type="image">
                    <left>0</left><top>108</top><width>1840</width><height>2</height>
                    <texture colordiffuse="10FFFFFF">white.png</texture>
                </control>
            </focusedlayout>
        </control>

        <!-- ════════ SEASON DROPDOWN (overlay, toggled via Window.Property(season_dd)) ════════ -->
        <control type="group">
            <visible>String.IsEqual(Window.Property(season_dd),1)</visible>
            <!-- dim the rest so the dropdown stands out -->
            <control type="image">
                <left>0</left><top>124</top><width>1920</width><height>916</height>
                <texture colordiffuse="CC000000">white.png</texture>
            </control>
            <!-- dropdown panel background -->
            <control type="image">
                <left>40</left><top>126</top><width>360</width><height>744</height>
                <texture colordiffuse="FF1E1E1E">white.png</texture>
            </control>
            <control type="image">
                <left>40</left><top>126</top><width>360</width><height>3</height>
                <texture colordiffuse="FFE50914">white.png</texture>
            </control>
            <control type="list" id="313">
                <left>40</left><top>134</top><width>360</width><height>730</height>
                <scrolltime tween="cubic" easing="out">180</scrolltime>
                <onleft>313</onleft><onright>313</onright>
                <itemlayout height="48" width="360">
                    <control type="label">
                        <left>18</left><top>0</top><width>324</width><height>48</height>
                        <font>font12</font><textcolor>FFAAAAAA</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <aligny>center</aligny>
                        <truncated>true</truncated>
                    </control>
                </itemlayout>
                <focusedlayout height="48" width="360">
                    <control type="image">
                        <left>0</left><top>0</top><width>360</width><height>48</height>
                        <texture colordiffuse="FFE50914">white.png</texture>
                    </control>
                    <control type="label">
                        <left>18</left><top>0</top><width>324</width><height>48</height>
                        <font>font12</font><textcolor>FFFFFFFF</textcolor>
                        <label>[B]$INFO[ListItem.Label][/B]</label>
                        <aligny>center</aligny>
                        <truncated>true</truncated>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </controls>
</window>
