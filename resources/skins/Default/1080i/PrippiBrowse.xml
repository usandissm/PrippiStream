<?xml version="1.0" encoding="utf-8"?>
<!--
  PrippiBrowse.xml — 1920×1080
  Single-screen category browser for PrippiStream.
  Macro tabs (top) + genre sidebar (left) + sort/breadcrumb bar + poster grid + hero box.

  Control IDs:
    122  EXIT button
    121  result-count label
    200  macro tab: FILM        201  macro tab: SERIE TV
    202  macro tab: K-DRAMA     203  macro tab: ANIME
    210  breadcrumb label (e.g. "FILM › Horror")
    211  sort toggle button (Più recenti / Meno recenti)
    140  genre sidebar list
    160  poster grid panel
    150  hero mini poster   151 hero title   152 hero meta   153 hero plot
    170  loading line group  171  empty/no-results label

  Per-card ListItem properties (set in prippihome.py _br_populate_grid):
    thumbnail → poster URL          ylabel → year text (badge)
  Window properties:
    macro → film|serie|kdrama|anime  (drives tab underline)
-->
<window>
    <allowmouse>true</allowmouse>
    <defaultcontrol>140</defaultcontrol>

    <animation type="WindowOpen" reversible="false">
        <effect type="fade" start="0" end="100" time="220" tween="sine"/>
    </animation>
    <animation type="WindowClose" reversible="false">
        <effect type="fade" start="100" end="0" time="150" tween="sine"/>
    </animation>

    <controls>

        <!-- Off-screen "focus park" button (id=165). Focus is parked here for an
             instant while the grid is repopulated, so addItems can't animate the panel
             back to the top (scroll-to-top glide). Self-referencing navigation means a
             held-down arrow key does nothing while focus is parked here. -->
        <control type="button" id="165">
            <left>-40</left><top>-40</top><width>1</width><height>1</height>
            <onup>165</onup><ondown>165</ondown><onleft>165</onleft><onright>165</onright>
        </control>

        <!-- Base background -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>1080</height>
            <texture colordiffuse="FA0D0D0D">white.png</texture>
        </control>

        <!-- ═══ TOP BAR (height 88) ═══ -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>88</height>
            <texture colordiffuse="E8000000">white.png</texture>
        </control>
        <!-- Logo -->
        <control type="image">
            <left>28</left><top>-4</top>
            <width>340</width><height>96</height>
            <texture>special://home/addons/plugin.video.prippistream/resources/media/logo_banner.png</texture>
            <aspectratio>keep</aspectratio>
        </control>

        <!-- Macro tabs -->
        <control type="button" id="200">
            <left>400</left><top>23</top><width>150</width><height>44</height>
            <texturefocus colordiffuse="60FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="14FFFFFF">white.png</texturenofocus>
            <label>FILM</label><font>font12</font>
            <textcolor>FFCCCCCC</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onright>201</onright><ondown>140</ondown>
        </control>
        <control type="image">
            <left>400</left><top>69</top><width>150</width><height>3</height>
            <texture colordiffuse="FFE50914">white.png</texture>
            <visible>String.IsEqual(Window.Property(macro),film)</visible>
        </control>

        <control type="button" id="201">
            <left>562</left><top>23</top><width>180</width><height>44</height>
            <texturefocus colordiffuse="60FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="14FFFFFF">white.png</texturenofocus>
            <label>SERIE TV</label><font>font12</font>
            <textcolor>FFCCCCCC</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onleft>200</onleft><onright>202</onright><ondown>140</ondown>
        </control>
        <control type="image">
            <left>562</left><top>69</top><width>180</width><height>3</height>
            <texture colordiffuse="FFE50914">white.png</texture>
            <visible>String.IsEqual(Window.Property(macro),serie)</visible>
        </control>

        <control type="button" id="202">
            <left>754</left><top>23</top><width>180</width><height>44</height>
            <texturefocus colordiffuse="60FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="14FFFFFF">white.png</texturenofocus>
            <label>K-DRAMA</label><font>font12</font>
            <textcolor>FFCCCCCC</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onleft>201</onleft><onright>203</onright><ondown>140</ondown>
        </control>
        <control type="image">
            <left>754</left><top>69</top><width>180</width><height>3</height>
            <texture colordiffuse="FFE50914">white.png</texture>
            <visible>String.IsEqual(Window.Property(macro),kdrama)</visible>
        </control>

        <control type="button" id="203">
            <left>946</left><top>23</top><width>150</width><height>44</height>
            <texturefocus colordiffuse="60FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="14FFFFFF">white.png</texturenofocus>
            <label>ANIME</label><font>font12</font>
            <textcolor>FFCCCCCC</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onleft>202</onleft><onright>122</onright><ondown>140</ondown>
        </control>
        <control type="image">
            <left>946</left><top>69</top><width>150</width><height>3</height>
            <texture colordiffuse="FFA78BFA">white.png</texture>
            <visible>String.IsEqual(Window.Property(macro),anime)</visible>
        </control>

        <!-- EXIT (id=122) -->
        <control type="button" id="122">
            <left>1788</left><top>23</top><width>104</width><height>44</height>
            <texturefocus colordiffuse="FFE50914">white.png</texturefocus>
            <texturenofocus colordiffuse="24FFFFFF">white.png</texturenofocus>
            <label>[B]EXIT[/B]</label><font>font10</font>
            <textcolor>FFFFFFFF</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <onleft>203</onleft><ondown>160</ondown>
        </control>

        <!-- ═══ SUB BAR: breadcrumb + count (top 96) ═══ -->
        <control type="label" id="210">
            <left>328</left><top>100</top><width>1000</width><height>34</height>
            <font>font13</font><textcolor>FFFFFFFF</textcolor>
            <shadowcolor>CC000000</shadowcolor><label></label>
            <aligny>center</aligny>
        </control>
        <control type="label" id="121">
            <left>1340</left><top>104</top><width>552</width><height>28</height>
            <font>font11</font><textcolor>FFAAAAAA</textcolor>
            <label></label><align>right</align><aligny>center</aligny>
        </control>

        <!-- Divider -->
        <control type="image">
            <left>320</left><top>150</top><width>1600</width><height>2</height>
            <texture colordiffuse="FF262626">white.png</texture>
        </control>
        <!-- loading line (id=170) — under the divider while fetching -->
        <control type="group" id="170">
            <control type="image">
                <left>320</left><top>152</top><width>1600</width><height>3</height>
                <texture colordiffuse="FF2A0406">white.png</texture>
            </control>
            <control type="image">
                <left>320</left><top>152</top><width>500</width><height>3</height>
                <texture colordiffuse="FFE50914">white.png</texture>
                <animation effect="slide" start="-500" end="1600" time="1100" tween="sine" loop="true">Visible</animation>
            </control>
        </control>

        <!-- ═══ GENRE SIDEBAR (id=140) ═══ -->
        <control type="image">
            <left>0</left><top>88</top><width>304</width><height>838</height>
            <texture colordiffuse="FF141414">white.png</texture>
        </control>
        <control type="label">
            <left>24</left><top>104</top><width>260</width><height>28</height>
            <font>font10</font><textcolor>FF777777</textcolor>
            <label>GENERI</label>
        </control>
        <control type="list" id="140">
            <left>12</left><top>148</top><width>284</width><height>772</height>
            <onright>160</onright>
            <onup>200</onup>
            <scrolltime tween="cubic" easing="out">200</scrolltime>
            <itemlayout height="48" width="284">
                <control type="label">
                    <left>20</left><top>0</top><width>250</width><height>48</height>
                    <font>font12</font><textcolor>FFBBBBBB</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <aligny>center</aligny><truncated>true</truncated>
                </control>
            </itemlayout>
            <focusedlayout height="48" width="284">
                <control type="image">
                    <left>0</left><top>2</top><width>284</width><height>44</height>
                    <texture colordiffuse="33E50914">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>2</top><width>4</width><height>44</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                </control>
                <control type="label">
                    <left>20</left><top>0</top><width>250</width><height>48</height>
                    <font>font12</font><textcolor>FFFFFFFF</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <aligny>center</aligny><truncated>true</truncated>
                </control>
            </focusedlayout>
        </control>

        <!-- ═══ POSTER GRID (id=160) ═══ -->
        <control type="panel" id="160">
            <left>320</left><top>160</top><width>1600</width><height>764</height>
            <scrolltime tween="cubic" easing="out">220</scrolltime>
            <scrollwrap>false</scrollwrap>
            <!-- ondown→150 (a NON-focusable image): at the last row DOWN is blocked
                 with no focus change, so the selection just stays. Pointing it at the
                 grid itself (160) instead sent a SET_FOCUS that reset the cursor to 0 —
                 the "jumps to the top when you press down while it's still loading" bug. -->
            <onleft>140</onleft><onup>200</onup><ondown>150</ondown>
            <itemlayout height="380" width="252">
                <control type="image">
                    <left>6</left><top>2</top><width>240</width><height>340</height>
                    <texture colordiffuse="20000000">white.png</texture>
                </control>
                <control type="image">
                    <left>8</left><top>4</top><width>236</width><height>336</height>
                    <texture>$INFO[ListItem.Property(thumbnail)]</texture>
                    <aspectratio>scale</aspectratio>
                </control>
                <!-- year badge -->
                <control type="image">
                    <left>14</left><top>12</top><width>64</width><height>26</height>
                    <texture colordiffuse="CC000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(ylabel))</visible>
                </control>
                <control type="label">
                    <left>14</left><top>12</top><width>64</width><height>26</height>
                    <font>font10</font><align>center</align><aligny>center</aligny>
                    <textcolor>FFE5E5E5</textcolor>
                    <label>$INFO[ListItem.Property(ylabel)]</label>
                    <visible>!String.IsEmpty(ListItem.Property(ylabel))</visible>
                </control>
                <control type="label">
                    <left>8</left><top>346</top><width>236</width><height>24</height>
                    <font>font10</font><textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>center</align><truncated>true</truncated>
                </control>
            </itemlayout>
            <focusedlayout height="380" width="252">
                <control type="image">
                    <left>1</left><top>0</top><width>250</width><height>344</height>
                    <texture colordiffuse="66000000">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="140" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="100" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>4</left><top>0</top><width>244</width><height>342</height>
                    <texture colordiffuse="F2FFFFFF">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="160" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="110" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>4</left><top>0</top><width>244</width><height>4</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                    <animation effect="fade" start="0" end="100" time="160" tween="sine">Focus</animation>
                    <animation effect="fade" start="100" end="0" time="110" tween="sine">Unfocus</animation>
                </control>
                <control type="image">
                    <left>6</left><top>2</top><width>240</width><height>336</height>
                    <texture>$INFO[ListItem.Property(thumbnail)]</texture>
                    <aspectratio>scale</aspectratio>
                    <animation effect="zoom" start="100" end="105" center="auto" time="180" tween="sine" easing="out">Focus</animation>
                    <animation effect="zoom" start="105" end="100" center="auto" time="130" tween="sine" easing="in">Unfocus</animation>
                </control>
                <control type="image">
                    <left>14</left><top>12</top><width>64</width><height>26</height>
                    <texture colordiffuse="DD000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(ylabel))</visible>
                </control>
                <control type="label">
                    <left>14</left><top>12</top><width>64</width><height>26</height>
                    <font>font10</font><align>center</align><aligny>center</aligny>
                    <textcolor>FFFFFFFF</textcolor>
                    <label>$INFO[ListItem.Property(ylabel)]</label>
                    <visible>!String.IsEmpty(ListItem.Property(ylabel))</visible>
                </control>
                <control type="label">
                    <left>6</left><top>346</top><width>240</width><height>24</height>
                    <font>font10</font><textcolor>FFFFFFFF</textcolor>
                    <shadowcolor>FF000000</shadowcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>center</align><truncated>true</truncated>
                </control>
            </focusedlayout>
        </control>

        <!-- empty / no-results (id=171) -->
        <control type="label" id="171">
            <left>320</left><top>480</top><width>1600</width><height>60</height>
            <font>font14</font><textcolor>FF777777</textcolor>
            <label>Seleziona un genere per vedere i titoli.</label>
            <align>center</align><aligny>center</aligny>
            <visible>false</visible>
        </control>

        <!-- ═══ HERO BOX (top 932, height 130) ═══ -->
        <control type="image">
            <left>0</left><top>932</top><width>1920</width><height>130</height>
            <texture colordiffuse="FF1A1A1A">white.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>932</top><width>1920</width><height>2</height>
            <texture colordiffuse="FF2E2E2E">white.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>932</top><width>6</width><height>130</height>
            <texture colordiffuse="FFE50914">white.png</texture>
        </control>
        <!-- hero mini poster — texture set at runtime via setImage(); start EMPTY
             (no 00-alpha colordiffuse, which Kodi would also apply to the runtime
             image, rendering it fully transparent / invisible). -->
        <control type="image" id="150">
            <left>28</left><top>946</top><width>72</width><height>102</height>
            <texture></texture>
            <aspectratio>scale</aspectratio>
        </control>
        <control type="label" id="151">
            <left>124</left><top>944</top><width>1660</width><height>36</height>
            <font>font13</font><textcolor>FFFFFFFF</textcolor>
            <shadowcolor>CC000000</shadowcolor><label></label>
            <aligny>center</aligny>
        </control>
        <control type="label" id="152">
            <left>124</left><top>982</top><width>1660</width><height>26</height>
            <font>font11</font><textcolor>FFB8B8B8</textcolor>
            <shadowcolor>CC000000</shadowcolor><label></label>
            <aligny>center</aligny>
        </control>
        <control type="label" id="153">
            <left>124</left><top>1010</top><width>1740</width><height>46</height>
            <font>font10</font><textcolor>FF9A9A9A</textcolor>
            <shadowcolor>CC000000</shadowcolor><label></label>
            <wrapwidth>1740</wrapwidth>
        </control>

    </controls>
</window>
