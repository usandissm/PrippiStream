<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <!-- ════════════════════════════════════════════════════════════════════
         PrippiStream settings.

         Many legacy Stream4me/Alfa settings are still READ by the live engine
         (playback, link resolution, TMDB, downloads, DNS). They are kept here as
         visible="false" with their defaults so the engine keeps working, but they
         are removed from the visible UI. Only genuinely-dead UI (action buttons,
         0-reference toggles) was deleted. Removing the dead ENGINE code behind the
         hidden settings is tracked as a future task ("Option 3").
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Generale -->
    <category label="70168">
        <setting id="addon_version_display" type="text" label="Versione installata" enable="false" default=""/>
        <setting label="70787" type="lsep"/>
        <setting id="autostart" type="bool" label="70706" default="true"/>
        <setting id="resolver_dns" type="bool" label="707408" default="true" enable="true" visible="true"/>
        <setting id="resolver_dns_provider" type="select" label="707409" default="Google" values="Cloudflare|Google" visible="eq(-1,true)"/>
        <setting label="70788" type="lsep"/>
        <setting id="debug" type="bool" label="30003" default="false"/>

        <!-- ── Hidden engine settings: read by the live engine, kept with their
             defaults; UI removed. Do NOT delete (would break playback / resolver /
             TMDB / downloads). See "Option 3" in memory for the real cleanup. ── -->
        <setting id="checkdns" type="bool" default="true" visible="false"/>
        <setting id="chrome_ua_version" type="text" default="120.0.6099.225" visible="false"/>
        <setting id="addon_update_enabled" type="bool" default="false" visible="false"/>
        <setting id="addon_update_message" type="bool" default="true" visible="false"/>
        <setting id="addon_update_timer" type="slider" option="int" range="1,1,24" default="1" visible="false"/>
        <!-- Playback engine (platformtools) -->
        <setting id="player_mode" type="select" lvalues="30026|30027|30028|30029" default="1" visible="false"/>
        <setting id="default_action" type="select" lvalues="30006|30007|30008" default="2" visible="false"/>
        <setting id="autoplay" type="bool" default="false" visible="false"/>
        <setting id="window_type" type="select" lvalues="60622|60623" default="0" visible="false"/>
        <setting id="resume_menu" type="select" lvalues="30048|30049" default="0" visible="false"/>
        <setting id="checklinks" type="bool" default="false" visible="false"/>
        <setting id="checklinks_number" type="slider" option="int" range="5,5,20" default="5" visible="false"/>
        <!-- Videolibrary engine (watched / next-episode / paths) -->
        <setting id="videolibrarypath" type="folder" default="" option="writeable" visible="false"/>
        <setting id="folder_tvshows" type="text" default="Serie TV" visible="false"/>
        <setting id="folder_movies" type="text" default="Film" visible="false"/>
        <setting id="videolibrary_kodi" type="bool" default="false" visible="false"/>
        <setting id="videolibrary_max_quality" type="bool" default="false" visible="false"/>
        <setting id="next_ep" type="select" lvalues="70832|70833|70732|70834" default="1" visible="false"/>
        <setting id="next_ep_type" type="select" lvalues="70755|70756|70757" default="0" visible="false"/>
        <setting id="next_ep_seconds" type="slider" option="int" range="20,10,240" default="40" visible="false"/>
        <setting id="watched_setting" type="slider" option="int" range="20,5,90" default="80" visible="false"/>
        <setting id="trakt_sync" type="bool" default="false" visible="false"/>
        <!-- Channels -->
        <setting id="channel_language" type="select" values="auto|all|ita" default="all" visible="false"/>
        <!-- Server / link resolution engine -->
        <setting id="resolve_priority" type="select" lvalues="70164|70165|70166" default="0" visible="false"/>
        <setting id="resolve_stop" type="bool" default="true" visible="false"/>
        <setting id="hidepremium" type="bool" default="false" visible="false"/>
        <setting id="httptools_timeout" type="slider" option="int" range="0,1,30" default="5" visible="false"/>
        <setting id="favorites_servers" type="bool" default="false" visible="false"/>
        <setting id="quality_priority" type="bool" default="false" visible="false"/>
        <setting id="elementum_on_seed" type="bool" default="false" visible="false"/>
        <!-- Search / TMDB engine -->
        <setting id="new_search" type="bool" default="true" visible="false"/>
        <setting id="last_search" type="bool" default="true" visible="false"/>
        <setting id="saved_searches_limit" type="slider" option="int" range="10,10,40" default="10" visible="false"/>
        <setting id="result_mode" type="select" lvalues="60675|60676" default="0" visible="false"/>
        <setting id="thread_number" type="slider" option="int" range="0,1,64" default="0" visible="false"/>
        <setting id="tmdb_active" type="bool" default="true" visible="false"/>
        <setting id="tmdb_plus_info" type="bool" default="false" visible="false"/>
        <setting id="episode_info" type="bool" default="false" visible="false"/>
        <setting id="tmdb_cache" type="bool" default="true" visible="false"/>
        <setting id="tmdb_cache_expire" type="select" lvalues="70158|70159|70160|70161|70170" default="4" visible="false"/>
        <setting id="lista_activa" type="text" default="addonfavorites-default.json" visible="false"/>
    </category>

    <!-- Download (feature PrippiStream "I miei download") -->
    <category label="30153">
        <setting id="downloadenabled" type="bool" label="70689" default="false"/>
        <setting id="downloadpath" type="folder" label="30017" visible="eq(-1,true)" default="" option="writeable"/>
        <setting id="download_concurrency" type="slider" label="32101" range="1,1,3" option="int" default="1"/>
        <setting id="show_downloads_row" type="bool" label="32103" default="true"/>
        <!-- Hidden legacy download settings (kept with defaults) -->
        <setting id="downloadlistpath" type="folder" default="" option="writeable" visible="false"/>
        <setting id="library_move" type="bool" default="true" visible="false"/>
        <setting id="browser" type="bool" default="true" visible="false"/>
        <setting id="server_speed" type="bool" default="true" visible="false"/>
        <setting id="language" type="select" values="ITA|Sub-ITA" default="ITA" visible="false"/>
        <setting id="quality" type="select" lvalues="70241|70763|70764|70765" default="0" visible="false"/>
    </category>

    <!-- Personalizzazione -->
    <category label="70126">
        <setting id="home_loop_rows" type="bool" label="Home: scorrendo oltre l'ultima riga torna alla prima" default="false"/>
        <setting id="show_adult_anime" type="bool" label="Sfoglia: mostra categorie Anime 18+ (Hentai, Ecchi, Yaoi, Yuri)" default="true"/>

        <!-- Hidden legacy customization settings (read by engine, kept with defaults) -->
        <setting id="touch_view" type="bool" default="false" visible="false"/>
        <setting id="viewchange_notify" type="bool" default="false" visible="false"/>
        <setting id="skin_name" type="text" default="skin.estuary" visible="false"/>
        <setting id="quick_menu" type="bool" default="true" visible="false"/>
        <setting id="infoplus" type="bool" default="false" visible="false"/>
        <setting id="icon_set" type="select" values="default|light|dark|mike" default="default" visible="false"/>
        <setting id="only_channel_icons" type="bool" default="false" visible="false"/>
        <setting id="enable_custom_theme" type="bool" default="false" visible="false"/>
        <setting id="custom_theme" type="folder" default="" visible="false"/>
        <setting id="video_thumbnail_type" type="select" lvalues="70132|70133" default="1" visible="false"/>
        <setting id="shortcut_key" type="action" action="RunPlugin(plugin://plugin.video.prippistream/?ew0KICAgICJhY3Rpb24iOiAia2V5bWFwIg0KfQ==)" visible="false"/>
        <setting id="view_mode_home" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_menu" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_channels" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_channel" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_movie" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_tvshow" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_season" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_episode" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_server" type="action" default="Default, 0" visible="false"/>
        <setting id="view_mode_musicvideo" type="action" default="Default, 0" visible="false"/>
    </category>

    <!-- Supporto -->
    <category label="Supporto">
        <setting label="Diagnostica" type="lsep"/>
        <setting id="send_log_to_dev" type="action"
                 label="Invia Log allo Sviluppatore"
                 action="RunPlugin(plugin://plugin.video.prippistream/?eyJhY3Rpb24iOiAic2VuZF9sb2dfdG9fZGV2IiwgImNoYW5uZWwiOiAic2V0dGluZyJ9)"/>
    </category>
</settings>
